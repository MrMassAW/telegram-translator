# --- Required ---
BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_google_gemini_api_key

# --- Admin & web (Mini App / API base URL as seen by Telegram) ---
ADMIN_USERNAME=admin
ADMIN_ID=123456789
WEB_APP_URL=https://your-public-host.example/

# Admin console: set SECRET_KEY for signed session cookies (use a long random string)
SECRET_KEY=
# Login: plain password (simplest) OR bcrypt hash (preferred for production)
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
# Set true when served over HTTPS so the session cookie is Secure
SESSION_COOKIE_SECURE=

# --- Database (default: SQLite file in project root) ---
DATABASE_URL=sqlite+aiosqlite:///./bot.db
# Docker Compose example (set automatically in docker-compose.yml):
# DATABASE_URL=sqlite+aiosqlite:////app/data/bot.db

# --- Stripe (optional; billing disabled if secret key missing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PACK_5=
STRIPE_PRICE_ID_PACK_10=
STRIPE_PRICE_ID_PACK_20=

# --- Gemini models (optional overrides) ---
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview

# --- Custom prompt file paths (optional; defaults in shared/prompts/) ---
# PROMPT_IMAGE_OCR_EXTRACT_FILE=
# PROMPT_IMAGE_HAS_TEXT_FILE=
# PROMPT_IMAGE_NATIVE_TRANSLATE_FILE=

# --- scripts/send_test_messages.py only ---
# SENDER_BOT_TOKEN=
# TEST_GROUP_ID=-1001234567890
